{
  "name": "@vnode/ts-printer",
  "version": "0.0.0",
  "license": "MIT",
  "displayName": "ts-printer",
  "description": "- [ ] Add project description for @vnode/ts-printer",
  "keywords": [],
  "homepage": "https://beemood.github.io/libs/ts-printer",
  "icon": "https://beemood.github.io/libs/ts-printer/assets/favicon.png",
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@vnode/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "license",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/ts-printer/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/ts-printer/dist",
          "main": "libs/ts-printer/src/index.ts",
          "tsConfig": "libs/ts-printer/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.11",
    "@vnode/errors": "workspace:*",
    "@vnode/logger": "workspace:*",
    "@vnode/types": "workspace:*",
    "@vnode/utils": "workspace:*"
  }
}
