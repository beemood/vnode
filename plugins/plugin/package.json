{
  "name": "@vnode/plugin",
  "version": "0.0.0",
  "license": "MIT",
  "displayName": "plugin",
  "description": "Executors and generators",
  "keywords": [
    "types",
    "interfaces"
  ],
  "homepage": "https://beemood.github.io/plugins/plugin",
  "icon": "https://beemood.github.io/plugins/plugin/assets/favicon.png",
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@vnode/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "generators.json"
  ],
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "plugins/plugin/dist",
          "main": "plugins/plugin/src/index.ts",
          "tsConfig": "plugins/plugin/tsconfig.lib.json",
          "rootDir": "plugins/plugin/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./plugins/plugin/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./plugins/plugin/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": "22.1.3",
    "tslib": "^2.3.0"
  },
  "generators": "./generators.json"
}
