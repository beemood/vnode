{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "Project",
  "title": "Project generator schema",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "Project type",
      "enum": ["cli", "library", "nestjs", "plugin"],
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What type would you like to use?"
    },
    "directory": {
      "directory": "string",
      "description": "Project directory",
      "$default": {
        "$source": "argv",
        "index": 1
      },
      "x-prompt": "What directory would you like to use?"
    }
  },
  "required": ["type", "directory"]
}
