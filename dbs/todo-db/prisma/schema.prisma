generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

generator swaggerGenerator {
  project  = "@vnode/todo-db"
  provider = "vnode-prisma-swagger"
  kind     = "swagger"
}

generator zodGenerator {
  project  = "@vnode/todo-db"
  provider = "vnode-prisma-zod"
  kind     = "zod"
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSES
}

model Category {
  id        Int       @id @default(autoincrement())
  uuid      String    @default(uuid(7)) @db.VarChar(255)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name String @unique @db.VarChar(255)

  /// @readonly
  parent   Category? @relation("children", fields: [parentId], references: [id])
  parentId Int?

  /// @readonly
  children Category[] @relation("children")

  /// @readonly
  todos Todo[]
}

model Todo {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title String @unique @db.VarChar(255)

  description String?

  active Boolean?

  notes String[]

  scores Int[]

  record Json

  records Json[]

  status Status? @default(OPEN)

  /// @readonly 
  category Category? @relation(fields: [categoryId], references: [id])

  categoryId Int?

  @@index([status])
  @@index([categoryId])
}
